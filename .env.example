# .env example

# Inspector runtime upload settings
INSPECTOR_SERVER_URL=http://your-inspector-host:3800
INSPECTOR_SERVER_API_KEY=replace-me
XIAOBA_INSPECTOR_MAX_UPLOAD_BYTES=20971520
INSPECTOR_AUTO_UPLOAD_ENABLED=true
INSPECTOR_AUTO_UPLOAD_TIME=20:00
INSPECTOR_AUTO_UPLOAD_STABLE_MINUTES=5
INSPECTOR_AUTO_UPLOAD_MAX_FILES=12

# Legacy log upload settings
LOG_UPLOAD_ENABLED=true
LOG_UPLOAD_SERVER_URL=http://118.145.116.152:3000
LOG_UPLOAD_INTERVAL_MINUTES=30

# Bundled runtimes are prepared during the Electron build.
# You should not need to configure node/python/git paths here.